# Claude API 키 — Anthropic 콘솔에서 발급 (https://console.anthropic.com/)
# 이 파일은 git에 커밋되는 템플릿. 실제 값은 .env 파일에 넣을 것 (.env는 gitignore).
CLAUDE_API_KEY=sk-ant-여기에_실제_키_붙여넣기

# (선택) ChromaDB persist 디렉토리 경로. 기본값: data/chroma_db
# RAG_CHROMA_DIR=data/chroma_db

# (선택) LangSmith 트레이싱 — https://smith.langchain.com 에서 API key 발급
# 다음 4개를 .env에 설정하면 RAG·에이전트 모든 LLM 호출이 자동 trace됨.
# 미설정 시 트레이싱 비활성 (정상 동작).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_여기에_실제_키_붙여넣기
# LANGSMITH_PROJECT=letsfutsal
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
